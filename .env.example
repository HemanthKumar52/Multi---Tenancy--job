# ── Apply Co-Pilot environment ───────────────────────────────────────────────
# Copy to .env and fill in. Everything here is OPTIONAL for local dev — the app
# falls back to SQLite + an offline tailoring/embedding path with no keys.

# App
APP_ENV=dev
SECRET_KEY=dev-only-change-me

# Database — leave unset to use SQLite (./storage/dev.sqlite3)
# DATABASE_URL=postgresql+psycopg://applycopilot:applycopilot@localhost:5432/applycopilot

# Redis (queue / browser-job broker) — optional in dev
# REDIS_URL=redis://localhost:6379/0

# LLM — set to enable Claude-quality tailoring & email classification.
# Without it, the deterministic offline engine is used.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_TAILOR_MODEL=claude-opus-4-8
ANTHROPIC_FAST_MODEL=claude-sonnet-4-6

# Apply automation (co-pilot). OFF by default — adapters refuse to submit unless APPLY_LIVE=1.
# A submission can NEVER reach a host outside APPLY_ALLOWED_HOSTS (https required for non-loopback;
# loopback only honored when APP_ENV=dev, for the local sandbox).
# APPLY_LIVE=0
# APPLY_ALLOWED_HOSTS=["127.0.0.1","localhost","boards.greenhouse.io","job-boards.greenhouse.io"]
# BROWSER_HEADLESS=1
# APPLY_TIMEOUT_MS=30000
# APPLY_DEBUG_SCREENSHOTS=0   # filled forms contain PII; only confirmation pages are captured by default

# Job discovery
# ADZUNA_APP_ID=...
# ADZUNA_APP_KEY=...

# Inbound email (forwarding-alias model). Domain you own for {user}@INBOUND_DOMAIN
INBOUND_DOMAIN=inbox.applycopilot.local
# POSTMARK_INBOUND_TOKEN=...

# Notifications (optional)
# TELEGRAM_BOT_TOKEN=...

# File storage (local dir in dev; S3-compatible in prod)
STORAGE_DIR=./storage
